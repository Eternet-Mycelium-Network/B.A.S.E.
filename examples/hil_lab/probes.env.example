# Copiar para probes.env e ajustar ao lab (não commit secrets/cmds destrutivos).
# source'ado por run_hil_lab_live.sh

# Programador real (exemplos):
# export BASE_HIL_PROGRAMMER_CMD='picotool load -f {image}'
# export BASE_HIL_PROGRAMMER_CMD='openocd -f interface/stlink.cfg -f target/stm32f4x.cfg -c "program {image} verify reset exit"'
# export BASE_HIL_PROGRAMMER_CMD='probe-rs download {image} --chip STM32F401RETx'

export BASE_HIL_PROGRAMMER_CMD="${BASE_HIL_PROGRAMMER_CMD:-picotool load -f {image}}"

# Probes extra além do catálogo (vid:pid hex):
# export BASE_HIL_PROBE_IDS='0483:374b,0d28:0204'

# Firmware real:
# export HIL_FW_IMAGE=/path/to/firmware.elf

# Só depois do SOW §HIL assinado:
# export HIL_SOW_SIGNED=1

export BASE_HIL_ALLOW_FLASH=1
export BASE_HIL_REQUIRE_LIVE=1
