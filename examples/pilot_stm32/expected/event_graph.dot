// B.A.S.E. Event Graph — Causal & Temporal
digraph "trace.csv" {
  rankdir=TB;
  splines=curved;
  node [fontname="JetBrains Mono", fontsize=10];
  edge [fontname="JetBrains Mono", fontsize=9];

  subgraph cluster_usart_init_to_tx_1 {
    label="usart_init_to_tx#1";
    style=filled; fillcolor="#1a1a2e"; fontcolor="#4a9eff";
    usart_init_to_tx_1_0 [label="WRITE 0x4001380c = 8196\n0x4001380c = 8196", shape=box, style=filled, fillcolor="#ff6b6b", fontcolor="#fff"];
    usart_init_to_tx_1_1 [label="READ 0x40013800\n0x40013800\n150ns", shape=box, style=filled, fillcolor="#ff8787", fontcolor="#fff"];
    usart_init_to_tx_1_2 [label="IRQ 0x25\n0x25\n500ns", shape=triangle, style=filled, fillcolor="#fcc419", fontcolor="#fff"];
    usart_init_to_tx_1_0 -> usart_init_to_tx_1_1 [label="150ns", color="#fab005", penwidth=2];
    usart_init_to_tx_1_1 -> usart_init_to_tx_1_2 [label="350ns", color="#fab005", penwidth=2];
  }

  subgraph cluster_usart_tx_byte_1 {
    label="usart_tx_byte#1";
    style=filled; fillcolor="#1a1a2e"; fontcolor="#4a9eff";
    usart_tx_byte_1_0 [label="WRITE 0x40013804 = 65\n0x40013804 = 65\n1000ns", shape=box, style=filled, fillcolor="#ff6b6b", fontcolor="#fff"];
    usart_tx_byte_1_1 [label="IRQ 0x25\n0x25\n1200ns", shape=triangle, style=filled, fillcolor="#fcc419", fontcolor="#fff"];
    usart_tx_byte_1_0 -> usart_tx_byte_1_1 [label="200ns", color="#fab005", penwidth=2];
  }

  // Legend
  leg_write [label="MMIO Write", shape=box, style=filled, fillcolor="#ff6b6b", fontcolor="#fff", fontsize=9];
  leg_dma [label="DMA Event", shape=diamond, style=filled, fillcolor="#da77f2", fontcolor="#fff", fontsize=9];
  leg_irq [label="Interrupt", shape=triangle, style=filled, fillcolor="#fcc419", fontcolor="#fff", fontsize=9];
  leg_lat [label="Latency", shape=plaintext, fontsize=9];
}
